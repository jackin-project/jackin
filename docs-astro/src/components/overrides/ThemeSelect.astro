---
import Select from '@astrojs/starlight/components/Select.astro'
---

<starlight-theme-select>
  <Select
    icon="laptop"
    label={Astro.locals.t('themeSelect.accessibleLabel')}
    options={[
      { label: Astro.locals.t('themeSelect.dark'), selected: true, value: 'dark' },
      { label: Astro.locals.t('themeSelect.light'), selected: false, value: 'light' },
    ]}
    width="6.25em"
  />
</starlight-theme-select>

{/* Inlined to avoid FOUC. Uses global scope from `ThemeProvider.astro`. */}
<script is:inline>
  StarlightThemeProvider.updatePickers();
</script>

<script>
  type Theme = 'dark' | 'light'

  const storageKey = 'starlight-theme'

  // Coerce any stored value (including the retired 'auto' or an empty
  // string from prior installs) to a known Theme. Default is dark.
  const parseTheme = (value: unknown): Theme =>
    value === 'light' ? 'light' : 'dark'

  const loadTheme = (): Theme =>
    parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey))

  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, theme)
    }
  }

  function onThemeChange(theme: Theme): void {
    ;(window as any).StarlightThemeProvider?.updatePickers?.(theme)
    document.documentElement.dataset.theme = theme
    storeTheme(theme)
  }

  class JackinThemeSelect extends HTMLElement {
    constructor() {
      super()
      onThemeChange(loadTheme())
      const select = this.querySelector('select')
      if (select) {
        select.value = loadTheme()
        select.addEventListener('change', (e) => {
          if (e.currentTarget instanceof HTMLSelectElement) {
            onThemeChange(parseTheme(e.currentTarget.value))
          }
        })
      }
    }
  }
  customElements.define('starlight-theme-select', JackinThemeSelect)
</script>
