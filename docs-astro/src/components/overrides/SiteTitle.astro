---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex" translate="no">
  <span class="wordmark">jackin<span class="tick">'</span></span>
</a>

<style>
  .site-title {
    align-items: center;
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }

  /* Landing-matched wordmark treatment (landing-footer-wordmark scaled
     for a top-nav slot). Heavy Inter, tight tracking, green tick. */
  .wordmark {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 1.375rem;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--sl-color-white);
    user-select: none;
  }

  .wordmark .tick {
    color: var(--jk-accent, #00ff41);
    text-shadow: 0 0 0.2em rgba(0, 255, 65, 0.45);
  }

  :root[data-theme='light'] .wordmark .tick {
    color: var(--jk-accent-dim, #00b82f);
    text-shadow: none;
  }
</style>
