---
import Default from '@astrojs/starlight/components/Head.astro'
---

<Default><slot /></Default>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;800;900&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,700&display=swap"
/>

<!-- Force dark as the initial theme on first visit (landing is dark-only;
     keeping docs consistent). Runs before Starlight's own theme script so
     there's no flash. User toggle still wins — we only set dark when no
     preference is stored. -->
<script is:inline>
  (function () {
    try {
      var stored = localStorage.getItem('starlight-theme');
      if (!stored) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    } catch (e) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>
