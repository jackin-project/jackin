{
  "problemMatcher": [
    {
      "owner": "jackin-xtask",
      "pattern": [
        {
          "regexp": "^([^:]+):(\\d+)(?::(\\d+))?:\\s*(error|warning):\\s*(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    },
    {
      "owner": "jackin-xtask-path-msg",
      "pattern": [
        {
          "regexp": "^\\s*([^:\\s][^:]*):(\\d+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      ]
    }
  ]
}
