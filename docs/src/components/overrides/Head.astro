---
import Default from '@astrojs/starlight/components/Head.astro'

// Each docs page gets its own generated OG card (see
// src/pages/og/[...slug].png.ts + astro-og-canvas). Fall back to the
// global landing image for the 404 page (no content entry → no OG
// static path → a per-page URL would 404) and anything else without
// a valid id.
const routeId = Astro.locals.starlightRoute.id
const hasPerPageOg = routeId && routeId !== '404'
const OG_IMAGE = hasPerPageOg
  ? `https://jackin.tailrocks.com/og/${routeId.replace(/\.(mdx?|astro)$/i, '')}.png`
  : 'https://jackin.tailrocks.com/og-image.png'

// Article meta — LinkedIn / FB honour these for og:type=article pages.
const section = routeId?.split('/')[0]
const sectionLabel = section
  ? section.charAt(0).toUpperCase() + section.slice(1).replace(/-/g, ' ')
  : undefined

// JSON-LD structured data for docs pages — search engines use this to
// render rich results (article cards with section/author/date).
const { entry } = Astro.locals.starlightRoute
const pageUrl = new URL(Astro.url.pathname, 'https://jackin.tailrocks.com').toString()
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry?.data.title,
  description: entry?.data.description,
  url: pageUrl,
  image: OG_IMAGE,
  inLanguage: 'en',
  articleSection: sectionLabel,
  isPartOf: {
    '@type': 'WebSite',
    name: "jackin'",
    url: 'https://jackin.tailrocks.com/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'jackin project',
    url: 'https://github.com/jackin-project',
  },
}

// BreadcrumbList structured data — gives Google a reliable crumb trail
// to render above the page title in search results. Derived from the
// content path (e.g. reference/architecture → Reference › Architecture)
// so it stays in sync with the sidebar without a second source of truth.
const crumbSegments = routeId ? routeId.replace(/\.(mdx?|astro)$/i, '').split('/') : []
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: 'https://jackin.tailrocks.com/',
  },
  ...crumbSegments.map((segment, i) => ({
    '@type': 'ListItem',
    position: i + 2,
    name: segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
    item: new URL(
      '/' + crumbSegments.slice(0, i + 1).join('/') + '/',
      'https://jackin.tailrocks.com/',
    ).toString(),
  })),
]
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
}
---

{/* Runs FIRST — before any stylesheet that could block its execution.
    Syncs data-theme with localStorage so every page renders in the
    correct theme from first paint (Starlight hardcodes data-theme to
    'dark' server-side, which flashed on navigations in light mode).

    On first visit we DON'T write to localStorage — leaving it empty
    lets Starlight's own ThemeProvider (which runs after us) still
    honour prefers-color-scheme if a user wants OS-following behaviour.
    Old 'auto' values are migrated away to 'dark' explicitly so the
    retired option doesn't linger.

    Adds .theme-init only when we actually flip the attribute. It
    disables every CSS transition for two animation frames after
    DOMContentLoaded so elements using var(--jk-brand) don't animate
    the dark-to-light colour shift. Skipped on default-dark loads
    where no flip happens. */}
<script is:inline>
  (function () {
    var root = document.documentElement
    var flipped = false
    try {
      var stored = localStorage.getItem('starlight-theme')
      // Migrate the retired 'auto' option — not first-visit empty values.
      if (stored === 'auto') {
        localStorage.removeItem('starlight-theme')
        stored = null
      }
      var theme = stored === 'light' ? 'light' : 'dark'
      if (root.getAttribute('data-theme') !== theme) {
        root.setAttribute('data-theme', theme)
        flipped = true
      }
    } catch (e) {
      // localStorage access threw (private mode, SecurityError, etc).
      // Leave whatever SSR wrote alone.
    }
    if (!flipped) return
    root.classList.add('theme-init')
    function releaseInit() {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          root.classList.remove('theme-init')
        })
      })
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', releaseInit, { once: true })
    } else {
      releaseInit()
    }
  })()
</script>

<Default><slot /></Default>

{/* Social preview image — Starlight sets og:title / og:description /
    twitter:card but not og:image. Adding both og:image and
    twitter:image so tweets / FB / Slack / Discord / LinkedIn shares
    render a full preview card. */}
<meta property="og:image" content={OG_IMAGE} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="jackin' — CLI for orchestrating AI coding agents in isolated Docker containers" />
<meta name="twitter:image" content={OG_IMAGE} />
<meta name="twitter:image:alt" content="jackin' — CLI for orchestrating AI coding agents in isolated Docker containers" />

{sectionLabel && <meta property="article:section" content={sectionLabel} />}

{/* Structured data for rich Google search results. */}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

{/* Favicons — Starlight auto-injects a single SVG favicon; iOS and
    Android home-screen adds prefer PNG rasters + an apple-touch-icon
    + a web app manifest. */}
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
<link rel="manifest" href="/site.webmanifest" />

{/* Tab overflow detection: watches each .tablist-wrapper and toggles
    a [data-overflow] attribute when the tablist's natural content
    width exceeds its container. CSS picks up the attribute and swaps
    in the chip layout (see docs-theme.css). Pure width-based — works
    at any viewport, no hard-coded breakpoint. */}
<script is:inline>
  (function () {
    function setup() {
      var wrappers = document.querySelectorAll('.tablist-wrapper')
      if (!wrappers.length) return
      function measure(wrapper) {
        var list = wrapper.querySelector('[role="tablist"]')
        if (!list) return
        // Temporarily unset overflow so we can measure natural width.
        wrapper.removeAttribute('data-overflow')
        var overflows = list.scrollWidth > list.clientWidth + 1
        if (overflows) wrapper.setAttribute('data-overflow', '')
      }
      var ro = new ResizeObserver(function (entries) {
        entries.forEach(function (e) { measure(e.target) })
      })
      wrappers.forEach(function (w) {
        measure(w)
        ro.observe(w)
      })
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup, { once: true })
    } else {
      setup()
    }
  })()
</script>

{/* Fonts are self-hosted via fontsource. See src/styles/fonts.css —
    Astro bundles the woff2 files same-origin and serves them directly,
    which is significantly faster than Google Fonts (no third-party DNS
    or TLS) and eliminates FOUT. */}
