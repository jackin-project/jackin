---
/**
 * High-level architecture diagram for /reference/architecture.
 *
 * Tree-style layout inside a single terminal-like panel. Reads top
 * to bottom as containment (Host > Docker > network > containers)
 * with monospace connector rules, not nested fieldset frames. The
 * brand accent lives only on (a) the CLI pill, because the operator
 * is the subject, and (b) the connection label between Agent and
 * DinD, because that's the defining runtime relationship.
 */
---

<figure class="jk-arch not-content" aria-label="jackin' runtime architecture: host machine running Docker Engine, with a per-agent network containing an Agent container linked to a DinD sidecar, plus three host-side persisted paths">
  <div class="jk-arch-panel">
    <header class="jk-arch-header">
      <span class="jk-arch-dot" aria-hidden="true" />
      <span class="jk-arch-dot" aria-hidden="true" />
      <span class="jk-arch-dot" aria-hidden="true" />
      <span class="jk-arch-title">runtime topology</span>
    </header>

    <div class="jk-arch-body">
      <div class="jk-arch-row jk-arch-row--root">
        <span class="jk-arch-label">host</span>
      </div>

      <div class="jk-arch-row jk-arch-row--cli">
        <span class="jk-arch-tree">├─</span>
        <span class="jk-arch-chip jk-arch-chip--accent">jackin CLI</span>
        <span class="jk-arch-note">operator interface</span>
      </div>

      <div class="jk-arch-row">
        <span class="jk-arch-tree">└─</span>
        <span class="jk-arch-label">Docker Engine</span>
      </div>

      <div class="jk-arch-row jk-arch-row--indent-1">
        <span class="jk-arch-tree">└─</span>
        <span class="jk-arch-net">jackin-agent-smith-net</span>
        <span class="jk-arch-note">per-agent network</span>
      </div>

      <div class="jk-arch-pair">
        <div class="jk-arch-service jk-arch-service--agent">
          <span class="jk-arch-service-name">Agent Container</span>
          <span class="jk-arch-service-role">Claude Code · mounted dirs</span>
        </div>
        <div class="jk-arch-link">
          <span class="jk-arch-link-label">tcp://dind:2376</span>
          <svg class="jk-arch-link-arrow" width="48" height="10" viewBox="0 0 48 10" fill="none" aria-hidden="true">
            <path d="M0 5 H44" stroke="currentColor" stroke-width="1.25" />
            <path d="M40 1 L44 5 L40 9" stroke="currentColor" stroke-width="1.25" fill="none" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="jk-arch-service jk-arch-service--dind">
          <span class="jk-arch-service-name">DinD Sidecar</span>
          <span class="jk-arch-service-role">docker:dind · TLS certs volume</span>
        </div>
      </div>

      <div class="jk-arch-rule" aria-hidden="true" />

      <div class="jk-arch-mounts">
        <span class="jk-arch-mounts-title">persisted on host</span>
        <div class="jk-arch-mounts-grid">
          <div class="jk-arch-mount">
            <code>~/.jackin/data/</code>
            <span>runtime state per instance</span>
          </div>
          <div class="jk-arch-mount">
            <code>~/.jackin/agents/</code>
            <span>cached agent repos</span>
          </div>
          <div class="jk-arch-mount">
            <code>~/.config/jackin/</code>
            <span>operator config</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</figure>

<style>
  .jk-arch {
    margin: 1.5rem 0 2rem;
    color: var(--jk-text);
  }

  /* One panel, terminal-styled. Borderless background with a single
     hairline — fewer visual "walls" than the old nested frames. */
  .jk-arch-panel {
    background: var(--jk-bg-deep);
    border: 1px solid var(--jk-ui);
    border-radius: 10px;
    overflow: hidden;
  }

  .jk-arch-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--jk-panel);
    border-bottom: 1px solid var(--jk-ui);
  }
  .jk-arch-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--jk-ui-strong);
  }
  .jk-arch-dot:first-child { background: color-mix(in srgb, var(--jk-brand) 60%, var(--jk-text-ghost)); }
  .jk-arch-title {
    margin-left: auto;
    font-family: var(--sl-font-system-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jk-text-ghost);
  }

  .jk-arch-body {
    padding: 18px 20px 20px;
    font-family: var(--sl-font-system-mono);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  /* Tree rows. The &mdash;&mdash; connectors are plain text inside a
     span so they scale with font and don't need a separate asset. */
  .jk-arch-row {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--jk-text);
  }
  .jk-arch-row--root {
    margin-bottom: 4px;
  }
  .jk-arch-row--cli { padding-left: 0; }
  .jk-arch-row--indent-1 { padding-left: 18px; }

  .jk-arch-tree {
    color: var(--jk-text-ghost);
    user-select: none;
  }
  .jk-arch-label {
    color: var(--jk-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
  }
  .jk-arch-note {
    color: var(--jk-text-ghost);
    font-size: 0.78rem;
  }
  .jk-arch-net {
    color: var(--jk-brand);
  }

  /* Chip / pill treatment for the single interactive element. */
  .jk-arch-chip {
    padding: 3px 10px;
    background: var(--jk-panel);
    border: 1px solid var(--jk-ui);
    border-radius: 999px;
    font-weight: 600;
  }
  .jk-arch-chip--accent {
    color: var(--jk-brand);
    border-color: color-mix(in srgb, var(--jk-brand) 50%, var(--jk-ui));
  }

  /* The Agent ↔ DinD row is the visual anchor. Two side-by-side
     cards inside the panel, separated by a labeled arrow. */
  .jk-arch-pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    gap: 12px;
    margin: 14px 0 14px 36px;
  }
  .jk-arch-service {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 14px;
    background: var(--jk-panel);
    border: 1px solid var(--jk-ui);
    border-radius: 8px;
  }
  .jk-arch-service--agent { border-left: 2px solid var(--jk-brand); }
  .jk-arch-service--dind  { border-left: 2px solid var(--jk-text-ghost); }
  .jk-arch-service-name {
    font-weight: 600;
    color: var(--jk-text);
    font-family: var(--sl-font-system);
    font-size: 0.92rem;
    letter-spacing: -0.005em;
  }
  .jk-arch-service-role {
    font-size: 0.78rem;
    color: var(--jk-text-dim);
  }

  .jk-arch-link {
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: var(--jk-brand);
  }
  .jk-arch-link-label {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--jk-text-ghost);
    white-space: nowrap;
  }

  .jk-arch-rule {
    height: 1px;
    background: var(--jk-ui);
    margin: 18px 0 14px;
  }

  /* Mount panel — same font family as the tree so it feels like
     another "branch" rather than a separate widget. */
  .jk-arch-mounts-title {
    display: block;
    color: var(--jk-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    margin-bottom: 10px;
  }
  .jk-arch-mounts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px 24px;
  }
  .jk-arch-mount {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .jk-arch-mount code {
    color: var(--jk-brand);
    background: transparent;
    padding: 0;
    font-size: 0.82rem;
  }
  .jk-arch-mount span {
    color: var(--jk-text-dim);
    font-family: var(--sl-font-system);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  @media (max-width: 640px) {
    .jk-arch-body { padding: 16px 14px; font-size: 0.8rem; }
    .jk-arch-pair {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      margin-left: 18px;
    }
    .jk-arch-link-arrow { transform: rotate(90deg); }
  }
</style>
