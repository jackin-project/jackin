{
  "name": "jackin-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "gen-og": "bun run scripts/gen-og.ts",
    "gen-icons": "bun run scripts/gen-icons.ts",
    "check:links": "lychee --config lychee.toml --include-fragments --remap \"https://jackin.tailrocks.com/(.*) file://$PWD/dist/\\$1\" --remap \"https://github.com/jackin-project/jackin/edit/main/(.*) file://$PWD/../\\$1\" --remap \"https://github.com/jackin-project/jackin/blob/main/(.*) file://$PWD/../\\$1\" --root-dir \"$PWD/dist\" 'dist/**/*.html'",
    "check:links:fresh": "bun run build && bun run check:links",
    "test": "bun test"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/starlight": "^0.38.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/fraunces": "^5.2.9",
    "astro": "^6.1.8",
    "astro-og-canvas": "^0.11.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "satori": "^0.26.0",
    "typescript": "^6.0.3"
  }
}
