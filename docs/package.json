{
  "name": "jackin-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/gen-crate-pages.ts && vite dev",
    "build": "bun run scripts/gen-crate-pages.ts && vite build && bun run scripts/prerender-static.ts",
    "preview": "vite preview",
    "start": "serve .output/public --config serve.json",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "gen-brand": "bun run scripts/gen-brand.ts",
    "gen-og": "bun run scripts/gen-og.ts",
    "check:repo-links": "cargo xtask docs repo-links",
    "check:roadmap-sidebar": "cargo xtask roadmap audit",
    "check:research-sidebar": "cargo xtask research check",
    "check:links": "lychee --config lychee.toml --include-fragments --remap \"https://jackin.tailrocks.com/(.*) file://$PWD/.output/public/\\$1\" --remap \"https://github.com/jackin-project/jackin/edit/main/(.*) file://$PWD/../\\$1\" --remap \"https://github.com/jackin-project/jackin/blob/main/(.*) file://$PWD/../\\$1\" --remap \"https://github.com/jackin-project/jackin/issues https://api.github.com/repos/jackin-project/jackin/issues\" --remap \"https://github.com/([^/]+)/([^/]+)/blob/([^/]+)/(.*) https://api.github.com/repos/\\$1/\\$2/contents/\\$4?ref=\\$3\" --remap \"https://github.com/([^/]+)/([^/]+)/tree/([^/]+)/(.*) https://api.github.com/repos/\\$1/\\$2/contents/\\$4?ref=\\$3\" --root-dir \"$PWD/.output/public\" '.output/public/**/*.html'",
    "check:links:fresh": "cargo xtask docs repo-links && bun run build && bun run check:links",
    "test": "bun test",
    "gen:crates": "bun run scripts/gen-crate-pages.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/fraunces": "^5.2.9",
    "@orama/orama": "^3.1.18",
    "@tailwindcss/vite": "^4.3.0",
    "@takumi-rs/image-response": "^2.0.0",
    "@tanstack/react-router": "^1.170.9",
    "@tanstack/react-start": "^1.168.16",
    "@tanstack/start-static-server-functions": "^1.167.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "fumadocs-core": "^16.9.2",
    "fumadocs-mdx": "^15.0.9",
    "fumadocs-ui": "^16.9.2",
    "lucide-react": "^1.17.0",
    "nitro": "^3.0.260522-beta",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0",
    "serve": "^14.2.6",
    "srvx": "^0.11.16",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@resvg/resvg-js": "2.6.2",
    "@types/bun": "1.3.14",
    "@types/fontkit": "2.0.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "fontkit": "2.0.4",
    "typescript": "6.0.3"
  }
}
